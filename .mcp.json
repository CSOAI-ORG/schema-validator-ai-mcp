{
  "name": "schema-validator-ai-mcp",
  "description": "Schema Validator Ai automation via MCP. Includes validate json schema, generate schema, convert openapi. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "validate_json_schema",
      "description": "Validate JSON data against a JSON Schema.",
      "parameters": {
        "type": "object",
        "properties": {
          "data_json": {
            "type": "string"
          },
          "schema_json": {
            "type": "string"
          }
        },
        "required": [
          "data_json",
          "schema_json"
        ]
      }
    },
    {
      "name": "generate_schema",
      "description": "Generate a JSON Schema from example JSON data.",
      "parameters": {
        "type": "object",
        "properties": {
          "data_json": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "data_json"
        ]
      }
    },
    {
      "name": "convert_openapi",
      "description": "Extract and convert schemas from an OpenAPI specification.",
      "parameters": {
        "type": "object",
        "properties": {
          "openapi_json": {
            "type": "string"
          },
          "extract_schemas": {
            "type": "boolean"
          }
        },
        "required": [
          "openapi_json"
        ]
      }
    },
    {
      "name": "validate_types",
      "description": "Validate that JSON data fields match expected types.",
      "parameters": {
        "type": "object",
        "properties": {
          "data_json": {
            "type": "string"
          },
          "type_spec": {
            "type": "object"
          }
        },
        "required": [
          "data_json",
          "type_spec"
        ]
      }
    }
  ]
}